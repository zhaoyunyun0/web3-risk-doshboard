# Copy to .env and fill in real values

# Lark webhook (required for alerts)
LARK_WEBHOOK_URL=https://open.larksuite.com/open-apis/bot/v2/hook/YOUR_HOOK_ID

# Optional: enable info-level push (in addition to warnings/alerts/critical)
LARK_PUSH_INFO=false

# Optional: minimum alert level to push (info|warning|alert|critical)
ALERT_MIN_LEVEL=warning

# Logging level (DEBUG|INFO|WARNING|ERROR)
LOG_LEVEL=INFO

# Chain allowlist (comma separated, empty = all configured)
ENABLED_CHAINS=ethereum

# Protocol allowlist (comma separated, empty = all configured)
ENABLED_PROTOCOLS=aave_v3

# Collect interval in seconds (core pools)
COLLECT_INTERVAL_SEC=60

# ---------- M4: Top 20 static holders via The Graph ----------
# Optional. If set, the /holders endpoint can return static aToken balance
# ranking via The Graph subgraph instead of net-flow approximation.
# 1. Get an API key: https://thegraph.com/studio/api-keys/
# 2. Subscribe to Aave v3 subgraph for each chain you need.
# 3. Paste the gateway URL below (one env var per chain).
# Format: https://gateway.thegraph.com/api/<KEY>/subgraphs/id/<SUBGRAPH_ID>
# If unset, the Web UI falls back to the net-flow ranking (no subgraph needed).
#
# THE_GRAPH_AAVE_V3_URL_ETHEREUM=
# THE_GRAPH_AAVE_V3_URL_ARBITRUM=
# THE_GRAPH_AAVE_V3_URL_OPTIMISM=
# THE_GRAPH_AAVE_V3_URL_BASE=
# THE_GRAPH_AAVE_V3_URL_POLYGON=
# THE_GRAPH_AAVE_V3_URL_BNB=

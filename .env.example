# Copy to .env and fill in real values

# Lark webhook (required for alerts)
LARK_WEBHOOK_URL=https://open.larksuite.com/open-apis/bot/v2/hook/YOUR_HOOK_ID

# Optional: enable info-level push (in addition to warnings/alerts/critical)
LARK_PUSH_INFO=false

# Optional: minimum alert level to push (info|warning|alert|critical)
ALERT_MIN_LEVEL=warning

# Logging level (DEBUG|INFO|WARNING|ERROR)
LOG_LEVEL=INFO

# Chain allowlist (comma separated, empty = all configured)
ENABLED_CHAINS=ethereum

# Protocol allowlist (comma separated, empty = all configured)
ENABLED_PROTOCOLS=aave_v3

# Collect interval in seconds (core pools)
COLLECT_INTERVAL_SEC=60
